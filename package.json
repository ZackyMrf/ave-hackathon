{
  "name": "ave-accumulation-monitor",
  "version": "1.0.0",
  "description": "Detect pre-movement accumulation signals in crypto tokens using Ave.ai API",
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ave-accumulation-monitor"
  },
  "keywords": [
    "crypto",
    "trading",
    "accumulation",
    "whale",
    "ave-ai",
    "pre-pump",
    "smart-money",
    "token-monitor"
  ],
  "requirements": {
    "python": ">=3.8",
    "dependencies": [
      "requests>=2.28.0",
      "python-telegram-bot>=20.0"
    ]
  },
  "environment": {
    "required": [
      "AVE_API_KEY"
    ],
    "optional": [
      "TELEGRAM_BOT_TOKEN",
      "TELEGRAM_CHAT_ID"
    ]
  },
  "entry_points": {
    "cli": "scripts/ave_monitor.py",
    "telegram": "telegram_bot.py",
    "scheduler": "alert_scheduler.py"
  },
  "commands": {
    "single": "python scripts/ave_monitor.py --mode single --token <TOKEN> --chain <CHAIN>",
    "sweep": "python scripts/ave_monitor.py --mode sweep --category <CAT> --chain <CHAIN>",
    "bot": "python telegram_bot.py",
    "alert": "python alert_scheduler.py"
  },
  "supported_chains": [
    "solana",
    "ethereum",
    "bsc",
    "base",
    "arbitrum",
    "optimism",
    "polygon",
    "avalanche"
  ],
  "api": {
    "provider": "Ave.ai",
    "version": "v2",
    "base_url": "https://prod.ave-api.com",
    "docs": "https://ave-cloud.gitbook.io/data-api"
  },
  "clawhub": {
    "slug": "ave-accumulation-monitor",
    "category": "finance",
    "tags": ["crypto", "trading", "analysis"]
  }
}
